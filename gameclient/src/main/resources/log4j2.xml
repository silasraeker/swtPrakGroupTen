<Configuration status="error" name="development">

    <!-- available logging targets -->
    <Appenders>
        <Console name="stdout" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-15c{1} %-5p %m%n"/>
        </Console>
        <File name="fout" fileName="logs/client.log" append="false">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-15c{1} %-5p %m%n"/>
        </File>
    </Appenders>

    <!-- used logging targets -->
    <Loggers>
        <AsyncRoot level="TRACE">
            <AppenderRef ref="fout" level="TRACE"/>
            <AppenderRef ref="stdout" level="WARN"/>
        </AsyncRoot>
    </Loggers>

</Configuration>